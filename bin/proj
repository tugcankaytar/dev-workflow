cat > ~/bin/proj << 'EOF'
#!/bin/bash

# ============================================
# PROJ - Project Layout Launcher
# Açtığın klasör için tmux layout oluşturur:
# - Sol büyük pane: Vim
# - Sağ üst pane: Claude Code (varsa)
# - Sağ alt pane: Terminal
# ============================================

# NOT: set -e KULLANMIYORUZ
# tmux has-session "session yok" durumunda exit code 1 döner,
# bu normal davranış ama set -e ile script ölür.

# Mevcut klasörü al
PROJECT_DIR="$(pwd)"

# Klasör adından session ismi türet
SESSION_NAME=$(basename "$PROJECT_DIR" | tr '. ' '_' | tr -d '[:punct:]' | tr '[:upper:]' '[:lower:]')

# Boşsa default
if [ -z "$SESSION_NAME" ]; then
    SESSION_NAME="default"
fi

# Mevcut session var mı? (if-then ile exit code güvenli kontrol)
if tmux has-session -t "$SESSION_NAME" 2>/dev/null; then
    SESSION_EXISTS=true
else
    SESSION_EXISTS=false
fi

if [ "$SESSION_EXISTS" = false ]; then
    # Yeni session oluştur
    tmux new-session -d -s "$SESSION_NAME" -c "$PROJECT_DIR" -n "main"
    
    # Dikey böl - sağ taraf %30
    tmux split-window -h -p 30 -c "$PROJECT_DIR" -t "$SESSION_NAME"
    
    # Sağ pane'i yatay böl
    tmux split-window -v -p 50 -c "$PROJECT_DIR" -t "$SESSION_NAME"
    
    # Pane 0: Vim
    tmux send-keys -t "$SESSION_NAME":0.0 "vim ." C-m
    
    # Pane 1: Claude Code
    if command -v claude &> /dev/null; then
        tmux send-keys -t "$SESSION_NAME":0.1 "claude" C-m
    else
        tmux send-keys -t "$SESSION_NAME":0.1 "echo 'Claude Code not installed. Install: npm i -g @anthropic-ai/claude-code'" C-m
    fi
    
    # Pane 2: Terminal
    tmux send-keys -t "$SESSION_NAME":0.2 "clear && git status 2>/dev/null || echo 'Ready'" C-m
    
    # Pane isimleri
    tmux select-pane -t "$SESSION_NAME":0.0 -T "Editor"
    tmux select-pane -t "$SESSION_NAME":0.1 -T "Claude"
    tmux select-pane -t "$SESSION_NAME":0.2 -T "Terminal"
    
    # Sol pane aktif
    tmux select-pane -t "$SESSION_NAME":0.0
fi

# Session'a bağlan
if [ -n "$TMUX" ]; then
    tmux switch-client -t "$SESSION_NAME"
else
    tmux attach-session -t "$SESSION_NAME"
fi
EOF

chmod +x ~/bin/proj
